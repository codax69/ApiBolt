{
  "name": "{{projectName}}",
  "version": "1.0.0",
  "description": "Backend API project bootstrapped with apibolt",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts"{{#if testing}},
    "test": "jest --runInBand --detectOpenHandles"{{/if}}
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0"{{#if (eq database "mongodb")}},
    "mongoose": "^8.3.1"{{/if}}{{#if (eq database "postgresql")}},
    "@prisma/client": "^5.12.1"{{/if}}{{#if auth}},
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2"{{/if}}{{#if (eq validation "zod")}},
    "zod": "^3.22.4"{{/if}}{{#if (eq validation "joi")}},
    "joi": "^17.12.3"{{/if}}{{#if logging}},
    "morgan": "^1.10.0",
    "winston": "^3.13.0"{{/if}}
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"{{#if (eq database "postgresql")}},
    "prisma": "^5.12.1"{{/if}}{{#if auth}},
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6"{{/if}}{{#if logging}},
    "@types/morgan": "^1.9.9"{{/if}}{{#if testing}},
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2"{{/if}}
  }{{#if testing}},
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node"
  }{{/if}}
}
