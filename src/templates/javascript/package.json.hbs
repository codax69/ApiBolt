{
  "name": "{{projectName}}",
  "version": "1.0.0",
  "description": "Backend API project bootstrapped with apibolt",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js"{{#if testing}},
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --detectOpenHandles"{{/if}}
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0"{{#if (eq database "mongodb")}},
    "mongoose": "^8.3.1"{{/if}}{{#if (eq database "postgresql")}},
    "@prisma/client": "^5.12.1"{{/if}}{{#if auth}},
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2"{{/if}}{{#if (eq validation "zod")}},
    "zod": "^3.22.4"{{/if}}{{#if (eq validation "joi")}},
    "joi": "^17.12.3"{{/if}}{{#if logging}},
    "morgan": "^1.10.0",
    "winston": "^3.13.0"{{/if}}
  },
  "devDependencies": {
    "nodemon": "^3.1.0"{{#if (eq database "postgresql")}},
    "prisma": "^5.12.1"{{/if}}{{#if testing}},
    "jest": "^29.7.0",
    "supertest": "^6.3.4"{{/if}}
  }{{#if testing}},
  "jest": {
    "testEnvironment": "node",
    "transform": {}
  }{{/if}}
}
